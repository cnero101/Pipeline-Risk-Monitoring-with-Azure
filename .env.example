# ── Azure Connection Strings ───────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Azure Event Hubs connection string
# Get from: portal.azure.com > pipeline-sensor-ns > Shared access policies > RootManageSharedAccessKey
EVENT_HUB_CONN_STR=Endpoint=sb://<your-namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<your-key>

# Azure Event Hub name
EVENT_HUB_NAME=pipeline-sensor-hub

# Azure Storage Account connection string
# Get from: portal.azure.com > pipeline608storage > Access keys > key1 > Connection string
STORAGE_CONN_STR=DefaultEndpointsProtocol=https;AccountName=<your-storage-account>;AccountKey=<your-key>;EndpointSuffix=core.windows.net

# Azure Logic App HTTP trigger URL
# Get from: portal.azure.com > pipeline-alerts > Logic app designer > HTTP trigger > HTTP POST URL
LOGIC_APP_URL=https://prod-<region>.logic.azure.com:443/workflows/<id>/triggers/manual/paths/invoke?...
